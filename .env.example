# City config (Karachi only for now)
CITY=karachi

# DagsHub / MLflow / DVC
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_REPO=your_dagshub_repo
DAGSHUB_TOKEN=your_dagshub_access_token

# Optional local override for where parquet is written before DVC add/push
FEATURE_STORE_PATH=data/features.parquet
